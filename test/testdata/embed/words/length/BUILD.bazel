load(
    "//cue:cue.bzl",
    "cue_consolidated_instance",
    "cue_exported_instance",
    "cue_instance",
)

exports_files([
    "length_def-golden.cue",
    "length-golden.yaml",
])

cue_instance(
    name = "length_instance",
    package_name = "words",
    # NB: Omit the "embedsrcs" attribute here deliberately, deferring
    # it until we get to the output targets below in order to exercise
    # proper consumption of that attribute.
    srcs = [
        "description.cue",
        "length.cue",
    ],
    ancestor = "//test/testdata/embed/words",
    deps = [
        "//test/testdata/embed/cue.mod/pkg/other-example.com/text",
    ],
)

cue_consolidated_instance(
    name = "length_def",
    embedsrcs = [
        "description.txt",
    ],
    instance = ":length_instance",
    visibility = ["//test:__subpackages__"],
)

cue_exported_instance(
    name = "length",
    embedsrcs = [
        "description.txt",
    ],
    instance = ":length_instance",
    output_format = "yaml",
    visibility = ["//test:__subpackages__"],
)
